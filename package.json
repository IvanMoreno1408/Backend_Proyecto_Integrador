{
  "name": "cms-multiportal-backend",
  "version": "1.0.0",
  "description": "CMS Multiportal Backend API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "test": "jest --testPathPattern='tests/(unit|property)' --runInBand",
    "test:property": "jest --testPathPattern='tests/property' --runInBand",
    "test:integration": "jest --testPathPattern='tests/integration' --runInBand",
    "test:coverage": "jest --coverage --runInBand"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.39.0",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.3.1",
    "express": "4.18.2",
    "express-rate-limit": "7.1.5",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "multer": "1.4.5-lts.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.11",
    "@types/jsonwebtoken": "9.0.5",
    "@types/multer": "1.4.11",
    "@types/node": "20.11.0",
    "@types/supertest": "2.0.16",
    "ci-info": "^4.4.0",
    "fast-check": "3.15.0",
    "jest": "29.7.0",
    "supertest": "6.3.4",
    "ts-jest": "29.1.2",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.3.3",
    "yargs": "^18.0.0",
    "yargs-parser": "^22.0.0"
  }
}
